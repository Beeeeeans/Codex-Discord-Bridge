{
  "name": "codex-discord-bridge",
  "version": "0.1.0",
  "description": "Discord thread bridge for persistent Codex CLI sessions using tmux.",
  "license": "MIT",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "pino": "^9.6.0",
    "strip-ansi": "^7.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
